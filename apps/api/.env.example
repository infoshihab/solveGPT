# Database (required by Drizzle / pg). The database must exist before the API starts.
# Repo Docker: docker compose up -d  →  postgresql://solvegpt:solvegpt@localhost:5432/solvegpt
# Local install: often use the default DB first, then migrate to a dedicated DB:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/postgres
DATABASE_URL=postgresql://solvegpt:solvegpt@localhost:5432/solvegpt

# Auth — JWT for email/password sessions (min 16 chars; use a long random string in production)
JWT_SECRET=change_me_to_a_long_random_secret

# Server — comma-separated allowed origins (dev also allows any localhost port)
PORT=4000
WEB_ORIGIN=http://localhost:3000,http://localhost:3001

# AES-256-GCM key: exactly 64 hex characters (32 bytes). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

# Optional: Redis for future distributed rate limits / sessions
# REDIS_URL=redis://localhost:6379

# Provider keys (demo placeholders — replace with real keys or store via Admin UI)
ANTHROPIC_API_KEY=sk-ant-api03-demo_replace_me
OPENAI_API_KEY=sk-proj-demo_replace_me
GROK_API_KEY=xai-demo_replace_me
GEMINI_API_KEY=demo_gemini_replace_me
